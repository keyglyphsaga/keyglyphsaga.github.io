---
const year = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Keyglyph Saga — Shadow</title>
    <meta name="description" content="Shadow — the first book in the Keyglyph Saga by Quentin Burroughs. A fantasy adventure awaits." />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Keyglyph Saga — Shadow" />
    <meta property="og:description" content="Shadow — the first book in the Keyglyph Saga by Quentin Burroughs. A fantasy adventure awaits." />
    <meta property="og:image" content="https://keyglyphsaga.github.io/og-image.png" />
    <meta property="og:url" content="https://keyglyphsaga.github.io" />
    <meta property="og:site_name" content="Keyglyph Saga" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Keyglyph Saga — Shadow" />
    <meta name="twitter:description" content="Shadow — the first book in the Keyglyph Saga by Quentin Burroughs. A fantasy adventure awaits." />
    <meta name="twitter:image" content="https://keyglyphsaga.github.io/og-image.png" />

    <link rel="icon" href="/favicon.ico" />
    <style>
      @font-face {
        font-family: 'Cardinal';
        src: url('/fonts/Cardinal.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
    </style>
  </head>
  <body>

    <section class="hero">
      <div class="hero-bg">
        <img src="/illustration-opt.jpg" alt="" class="hero-bg-img" />
      </div>

      <canvas id="particles" class="particles-canvas"></canvas>

      <div class="hero-content">
        <div class="keyglyph-top">
          <img src="/shadow-keyglyph-new.svg" alt="Shadow Keyglyph" class="keyglyph-top-img" />
        </div>

        <h1 class="title">Shadow</h1>
        <p class="subtitle">The Keyglyph Saga</p>
        <p class="author">by Quentin Burroughs</p>

        <a href="https://www.amazon.com" class="cta-button" target="_blank" rel="noopener">
          Buy on Amazon
        </a>
      </div>
    </section>

    <footer>
      <p>&copy; {year} Quentin Burroughs. All rights reserved.</p>
    </footer>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        width: 100%;
        overflow-x: hidden;
        background: linear-gradient(135deg, #761E2E 0%, #213998 100%);
        min-height: 100vh;
      }

      .hero {
        position: relative;
        width: 100%;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }

      .hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
      }

      .particles-canvas {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
      }

      .hero-bg-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
        mask-image: radial-gradient(ellipse 70% 65% at center, #000 40%, transparent 100%);
        -webkit-mask-image: radial-gradient(ellipse 70% 65% at center, #000 40%, transparent 100%);
      }

      .hero-content {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        text-align: center;
      }

      .keyglyph-top {
        margin-bottom: 1.5rem;
        animation: float 3s ease-in-out infinite;
      }

      .keyglyph-top-img {
        width: 120px;
        height: 120px;
        filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.9))
                drop-shadow(0 0 30px rgba(255, 255, 255, 0.7))
                drop-shadow(0 0 50px rgba(255, 255, 255, 0.5))
                drop-shadow(0 0 80px rgba(255, 255, 255, 0.3));
      }

      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
      }

      .title {
        font-family: 'Cardinal', 'Times New Roman', serif;
        font-size: clamp(3.5rem, 10vw, 7rem);
        font-weight: 700;
        color: #fff;
        line-height: 1;
        text-shadow: 0 2px 20px rgba(0, 0, 0, 0.6), 0 0 60px rgba(0, 0, 0, 0.3);
        margin-bottom: 0.15em;
      }

      .subtitle {
        font-family: 'Cardinal', 'Times New Roman', serif;
        font-size: clamp(1.1rem, 3vw, 1.8rem);
        color: #fff;
        margin-bottom: 0.2em;
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
        letter-spacing: 0.02em;
      }

      .author {
        font-family: system-ui, -apple-system, sans-serif;
        font-size: clamp(0.85rem, 1.5vw, 1rem);
        color: rgba(255, 255, 255, 0.85);
        margin-bottom: 1.8rem;
        text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
        letter-spacing: 0.03em;
      }

      .cta-button {
        display: inline-block;
        padding: 14px 44px;
        background: #761E2E;
        color: #fff;
        font-family: system-ui, -apple-system, sans-serif;
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        text-decoration: none;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
        transition: all 0.3s ease;
      }

      .cta-button:hover {
        background: #213998;
        transform: translateY(-2px);
        box-shadow: 0 6px 30px rgba(33, 57, 152, 0.5);
      }

      .cta-button:active {
        background: #1a2e7a;
        transform: translateY(0);
      }

      footer {
        position: relative;
        z-index: 2;
        text-align: center;
        padding: 1.5rem;
      }

      footer p {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.35);
        font-family: system-ui, -apple-system, sans-serif;
        margin: 0;
      }

      @media (max-width: 768px) {
        .hero-content {
          padding: 2rem 1.5rem;
        }
        .keyglyph-top-img {
          width: 90px;
          height: 90px;
        }
        .cta-button {
          padding: 12px 32px;
          font-size: 0.9rem;
        }
      }
    </style>
    <script>
      const canvas = document.getElementById('particles');
      const ctx = canvas.getContext('2d');
      let particles = [];
      const COUNT = 50;

      function resize() {
        const hero = canvas.parentElement;
        canvas.width = hero.offsetWidth;
        canvas.height = hero.offsetHeight;
      }

      function createParticle() {
        return {
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          r: Math.random() * 3 + 1,
          dx: (Math.random() - 0.5) * 0.4,
          dy: -(Math.random() * 0.3 + 0.1),
          opacity: Math.random() * 0.6 + 0.2,
          fadeDir: Math.random() > 0.5 ? 1 : -1,
        };
      }

      function init() {
        resize();
        particles = [];
        for (let i = 0; i < COUNT; i++) particles.push(createParticle());
      }

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (const p of particles) {
          p.x += p.dx;
          p.y += p.dy;
          p.opacity += p.fadeDir * 0.003;
          if (p.opacity >= 0.8) p.fadeDir = -1;
          if (p.opacity <= 0.1) p.fadeDir = 1;

          if (p.y < -10 || p.x < -10 || p.x > canvas.width + 10) {
            Object.assign(p, createParticle(), { y: canvas.height + 10 });
          }

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(200, 30, 40, ${p.opacity})`;
          ctx.shadowColor = 'rgba(200, 30, 40, 0.6)';
          ctx.shadowBlur = 8;
          ctx.fill();
          ctx.shadowBlur = 0;
        }
        requestAnimationFrame(draw);
      }

      window.addEventListener('resize', resize);
      init();
      draw();
    </script>
  </body>
</html>
