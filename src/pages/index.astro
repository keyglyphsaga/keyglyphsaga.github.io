---
const year = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Keyglyph Saga</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <main>
      <img src="/placeholder.svg" alt="Keyglyph Saga" class="hero" />
      <h1>Keyglyph Saga</h1>
      <p class="tagline">Coming Soon</p>
    </main>
    <footer>
      <p>&copy; {year} Keyglyph Saga. All rights reserved.</p>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: #0a0a0f;
    --text: #e0dfe4;
    --accent: #7c6fea;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: system-ui, -apple-system, sans-serif;
  }

  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }

  .hero {
    width: 100%;
    max-width: 480px;
    height: auto;
    margin-bottom: 2rem;
    border-radius: 12px;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 0.5rem;
    letter-spacing: 0.02em;
    color: var(--accent);
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.7;
    margin: 0;
  }

  footer {
    text-align: center;
    padding: 1.5rem;
    font-size: 0.85rem;
    opacity: 0.5;
  }
</style>
