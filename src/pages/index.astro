---
const year = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Keyglyph Saga — Shadow</title>
    <meta name="description" content="Shadow — the first book in the Keyglyph Saga by Quentin Burroughs. A fantasy adventure awaits." />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Keyglyph Saga — Shadow" />
    <meta property="og:description" content="Shadow — the first book in the Keyglyph Saga by Quentin Burroughs. A fantasy adventure awaits." />
    <meta property="og:image" content="https://keyglyphsaga.github.io/og-image.png" />
    <meta property="og:url" content="https://keyglyphsaga.github.io" />
    <meta property="og:site_name" content="Keyglyph Saga" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Keyglyph Saga — Shadow" />
    <meta name="twitter:description" content="Shadow — the first book in the Keyglyph Saga by Quentin Burroughs. A fantasy adventure awaits." />
    <meta name="twitter:image" content="https://keyglyphsaga.github.io/og-image.png" />

    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Gelasio:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <style>
      @font-face {
        font-family: 'Cardinal';
        src: url('/fonts/Cardinal.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
    </style>
  </head>
  <body>

    <!-- Full-page hero with illustration background -->
    <section class="hero">
      <div class="hero-bg">
        <img src="/illustration.png" alt="" class="hero-bg-img" />
      </div>

      <div class="hero-content">
        <!-- Book cover -->
        <div class="book-cover">
          <img src="/mockup2.png" alt="Shadow — The Keyglyph Saga book cover" class="book-img" />
        </div>

        <!-- Title block -->
        <h1 class="title">Shadow</h1>
        <p class="subtitle">The Keyglyph Saga</p>
        <p class="author">by Quentin Burroughs</p>

        <!-- CTA -->
        <a href="https://www.amazon.com" class="cta-button" target="_blank" rel="noopener">
          Buy on Amazon
        </a>

        <!-- Keyglyph symbol -->
        <div class="keyglyph-symbol">
          <img src="/shadow-keyglyph-new.svg" alt="" class="keyglyph-img" />
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <p>&copy; {year} Quentin Burroughs. All rights reserved.</p>
    </footer>

    <style>
      :root {
        --font-display: 'Cardinal', 'Times New Roman', serif;
        --font-body: 'Gelasio', Georgia, serif;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        width: 100%;
        overflow-x: hidden;
        background: #000;
      }

      /* ── Hero Section ── */
      .hero {
        position: relative;
        width: 100%;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }

      .hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
      }

      .hero-bg-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
      }

      .hero-content {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        text-align: center;
      }

      /* ── Book Cover ── */
      .book-cover {
        margin-bottom: 1.5rem;
      }

      .book-img {
        width: 140px;
        height: auto;
        transform: perspective(800px) rotateY(-8deg);
        filter: drop-shadow(0 8px 30px rgba(0, 0, 0, 0.5));
        transition: transform 0.4s ease;
      }

      .book-img:hover {
        transform: perspective(800px) rotateY(0deg) scale(1.05);
      }

      /* ── Title ── */
      .title {
        font-family: var(--font-display);
        font-size: clamp(3.5rem, 10vw, 7rem);
        font-weight: 700;
        color: #fff;
        line-height: 1;
        text-shadow: 0 2px 20px rgba(0, 0, 0, 0.6), 0 0 60px rgba(0, 0, 0, 0.3);
        margin-bottom: 0.15em;
      }

      .subtitle {
        font-family: var(--font-display);
        font-size: clamp(1.1rem, 3vw, 1.8rem);
        color: #fff;
        margin-bottom: 0.2em;
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
        letter-spacing: 0.02em;
      }

      .author {
        font-family: system-ui, -apple-system, sans-serif;
        font-size: clamp(0.85rem, 1.5vw, 1rem);
        color: rgba(255, 255, 255, 0.85);
        margin-bottom: 1.8rem;
        text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
        letter-spacing: 0.03em;
      }

      /* ── CTA Button ── */
      .cta-button {
        display: inline-block;
        padding: 14px 44px;
        background: linear-gradient(to bottom, #cc1111, #880000);
        color: #fff;
        font-family: system-ui, -apple-system, sans-serif;
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        text-decoration: none;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.15);
        transition: all 0.3s ease;
        margin-bottom: 2rem;
      }

      .cta-button:hover {
        background: linear-gradient(to bottom, #dd2222, #aa0000);
        transform: translateY(-2px);
        box-shadow: 0 6px 30px rgba(180, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.2);
      }

      /* ── Keyglyph Symbol ── */
      .keyglyph-symbol {
        opacity: 0.8;
      }

      .keyglyph-img {
        width: 70px;
        height: 70px;
        filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.4));
      }

      /* ── Footer ── */
      footer {
        position: relative;
        z-index: 2;
        text-align: center;
        padding: 1.5rem;
        background: #000;
      }

      footer p {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.35);
        font-family: system-ui, -apple-system, sans-serif;
        margin: 0;
      }

      /* ── Responsive ── */
      @media (max-width: 768px) {
        .hero-content {
          padding: 2rem 1.5rem;
        }
        .book-img {
          width: 110px;
        }
        .cta-button {
          padding: 12px 32px;
          font-size: 0.9rem;
        }
        .keyglyph-img {
          width: 55px;
          height: 55px;
        }
      }
    </style>
  </body>
</html>
