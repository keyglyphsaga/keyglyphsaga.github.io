---
const year = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Keyglyph Saga — Shadow</title>
    <meta name="description" content="Shadow — the first book in the Keyglyph Saga by Quentin Burroughs. A fantasy adventure awaits." />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Keyglyph Saga — Shadow" />
    <meta property="og:description" content="Shadow — the first book in the Keyglyph Saga by Quentin Burroughs. A fantasy adventure awaits." />
    <meta property="og:image" content="https://keyglyphsaga.github.io/og-image.png" />
    <meta property="og:url" content="https://keyglyphsaga.github.io" />
    <meta property="og:site_name" content="Keyglyph Saga" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Keyglyph Saga — Shadow" />
    <meta name="twitter:description" content="Shadow — the first book in the Keyglyph Saga by Quentin Burroughs. A fantasy adventure awaits." />
    <meta name="twitter:image" content="https://keyglyphsaga.github.io/og-image.png" />

    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Gelasio:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <style>
      @font-face {
        font-family: 'Cardinal';
        src: url('/fonts/Cardinal.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
    </style>
  </head>
  <body>
    <!-- Floating particles -->
    <div class="particles" aria-hidden="true">
      {Array.from({ length: 20 }).map((_, i) => (
        <span class="particle" style={`--i: ${i}; --x: ${Math.random() * 100}; --delay: ${Math.random() * 8}s; --duration: ${6 + Math.random() * 6}s; --size: ${3 + Math.random() * 5}px;`} />
      ))}
    </div>

    <!-- Floating Keyglyph -->
    <section class="keyglyph-hero">
      <div class="keyglyph-float">
        <div class="keyglyph-glow"></div>
        <img src="/shadow-keyglyph.svg" alt="Shadow Keyglyph" class="keyglyph-svg" />
      </div>
      <div class="keyglyph-shadow"></div>
      <h1 class="glyph-title">Shadow</h1>
      <p class="glyph-subtitle">The Keyglyph Saga</p>
      <p class="glyph-author">by Quentin Burroughs</p>
    </section>



    <!-- Illustration section -->
    <section class="illustration-section">
      <img src="/illustration.png" alt="Characters beneath the glowing trees of the Keyglyph world" class="illustration" />
    </section>

    <!-- About section -->
    <section class="about">
      <div class="about-inner">
        <h2>Enter the World</h2>
        <p>
          In a realm where ancient glyphs hold the keys to unimaginable power, four young heroes find themselves drawn together by fate — and hunted by shadows that should not exist.
        </p>
        <p>
          <em>Shadow</em> is the first book in the Keyglyph Saga, a fantasy adventure that blends mystery, friendship, and a world where nothing is quite what it seems.
        </p>
        <div class="about-cta">
          <a href="https://www.amazon.com" class="cta cta-secondary" target="_blank" rel="noopener">
            Get Your Copy
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <img src="/element.png" alt="" class="footer-mark" />
      <p>&copy; {year} Quentin Burroughs. All rights reserved.</p>
    </footer>
  </body>
</html>

<style>
  /* ── Tokens ── */
  :root {
    --red-bright: #e8384f;
    --red: #d41b2c;
    --red-dark: #8b1a2b;
    --red-rose: #c4647a;

    --purple: #7c3aed;
    --purple-mid: #6d28d9;

    --blue-electric: #3b82f6;
    --blue-bright: #60a5fa;
    --blue: #4a8fd4;
    --blue-deep: #1e3a8a;

    --text: #f0e8f0;
    --text-secondary: #d4c6e8;
    --text-muted: #a78bfa;

    --font-display: 'Cardinal', Georgia, serif;
    --font-body: 'Gelasio', Georgia, serif;
  }

  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; }
  html {
    background: var(--blue-deep);
    color: var(--text);
    font-family: var(--font-body);
    scroll-behavior: smooth;
  }
  body {
    margin: 0;
    min-height: 100vh;
    overflow-x: hidden;
    background: linear-gradient(
      180deg,
      #dc2626 0%,
      #b91c1c 8%,
      #991b1b 15%,
      #7c2d8e 28%,
      #6d28d9 40%,
      #4c1d95 50%,
      #3730a3 60%,
      #1e3a8a 72%,
      #1e40af 82%,
      #2563eb 92%,
      #3b82f6 100%
    );
  }
  img { max-width: 100%; height: auto; display: block; }

  /* ── Particles ── */
  .particles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .particle {
    position: absolute;
    width: var(--size);
    height: var(--size);
    background: rgba(255, 255, 255, 0.6);
    border-radius: 50%;
    opacity: 0;
    left: calc(var(--x) * 1%);
    animation: float var(--duration) var(--delay) infinite ease-in-out;
  }
  @keyframes float {
    0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.5; }
    90% { opacity: 0.2; }
    100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
  }

  /* ── Floating Keyglyph ── */
  .keyglyph-hero {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem 2rem;
  }

  .keyglyph-float {
    position: relative;
    animation: zelda-float 3s ease-in-out infinite;
  }

  .keyglyph-glow {
    position: absolute;
    inset: -30px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0.1) 40%, transparent 70%);
    filter: blur(20px);
    border-radius: 50%;
    animation: glow-pulse 3s ease-in-out infinite;
  }

  .keyglyph-svg {
    position: relative;
    width: 160px;
    height: 160px;
    filter: invert(1) drop-shadow(0 0 15px rgba(255, 255, 255, 0.8)) drop-shadow(0 0 40px rgba(255, 255, 255, 0.4));
  }

  .keyglyph-shadow {
    width: 100px;
    height: 14px;
    margin-top: 1rem;
    background: radial-gradient(ellipse, rgba(0, 0, 0, 0.3) 0%, transparent 70%);
    border-radius: 50%;
    animation: shadow-pulse 3s ease-in-out infinite;
  }

  @keyframes zelda-float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-18px);
    }
  }

  @keyframes glow-pulse {
    0%, 100% {
      opacity: 0.7;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
    }
  }

  @keyframes shadow-pulse {
    0%, 100% {
      transform: scaleX(1);
      opacity: 0.3;
    }
    50% {
      transform: scaleX(0.7);
      opacity: 0.15;
    }
  }

  .glyph-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 700;
    color: #fff;
    margin: 1.5rem 0 0.5rem;
    letter-spacing: 0.03em;
    text-shadow: 0 2px 30px rgba(255, 255, 255, 0.3);
    line-height: 1;
  }

  .glyph-subtitle {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    color: #fff;
    margin: 0 0 0.5rem;
    letter-spacing: 0.1em;
  }

  .glyph-author {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: clamp(0.85rem, 2vw, 1.1rem);
    color: #fff;
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
  }
  .hero-inner {
    max-width: 1100px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .series-label {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 0.5rem;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 700;
    line-height: 1;
    margin: 0 0 0.75rem;
    color: #fff;
    letter-spacing: 0.02em;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  .author {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin: 0 0 1.5rem;
  }
  .author strong {
    color: #fff;
  }

  .tagline {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-style: italic;
    color: var(--text-secondary);
    margin: 0 0 2rem;
    line-height: 1.6;
    max-width: 420px;
  }

  /* ── CTA ── */
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 2px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 8px;
    transition: all 0.25s ease;
    letter-spacing: 0.02em;
  }
  .cta:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
  }
  .cta-secondary {
    background: rgba(255, 255, 255, 0.1);
    border: 2px solid rgba(255, 255, 255, 0.2);
  }
  .cta-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
  }

  /* ── Book ── */
  .hero-book {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .book-glow {
    position: absolute;
    width: 80%;
    height: 80%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
    filter: blur(40px);
    z-index: 0;
  }
  .book-cover {
    position: relative;
    z-index: 1;
    max-width: 440px;
    width: 100%;
    border-radius: 8px;
    filter: drop-shadow(0 20px 60px rgba(0, 0, 0, 0.4));
    transition: transform 0.4s ease;
  }
  .book-cover:hover {
    transform: scale(1.03) rotate(-1deg);
  }

  /* ── Illustration ── */
  .illustration-section {
    position: relative;
    z-index: 1;
    overflow: hidden;
  }
  .illustration {
    width: 100%;
    display: block;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  /* ── About ── */
  .about {
    position: relative;
    z-index: 1;
    padding: 6rem 2rem;
    text-align: center;
  }
  .about-inner {
    max-width: 640px;
    margin: 0 auto;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 3rem;
  }
  h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 1.5rem;
  }
  .about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin: 0 0 1.25rem;
  }
  .about-cta {
    margin-top: 2.5rem;
  }

  /* ── Footer ── */
  footer {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 3rem 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .footer-mark {
    width: 28px;
    height: 28px;
    margin: 0 auto 1rem;
    filter: invert(1);
    opacity: 0.3;
  }
  footer p {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .keyglyph-hero {
      padding: 4rem 1.5rem 1rem;
    }
    .keyglyph-svg {
      width: 120px;
      height: 120px;
    }
    .hero {
      padding: 2rem 1.5rem;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }
    .hero-text {
      order: 1;
    }
    .hero-book {
      order: 0;
    }
    .tagline {
      margin-left: auto;
      margin-right: auto;
    }
    .book-cover {
      max-width: 320px;
    }
    .about-inner {
      padding: 2rem 1.5rem;
    }
  }
</style>
